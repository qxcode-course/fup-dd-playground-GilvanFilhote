            "content": "package main\nimport \"fmt\"\nfunc main() {\n    var quant_album, quant_fig_baruel int\n    fmt.Scan(&quant_album, &quant_fig_baruel)\n    cont:= make([]int, quant_album+1)\n\n    for i:=0; i<quant_fig_baruel; i++{\n        var fig int\n        fmt.Scan(&fig)\n        cont[fig]++\n    }\n    \n    fmt.Printf(\"[\")\n    for i:=1; i<=quant_album; i++{\n        if cont[i]>1{\n        for j:=0; j<cont[i]-1; j++{\n        fmt.Print(\" \", i)\n        \n        }\n    }\n}\n    fmt.Printf(\" ]\\n\")\n    fmt.Printf(\"[\")\n    \n    for i:=1; i<=quant_album; i++{\n        if cont[i]==0{\n        fmt.Print(\" \", i)\n       \n        }\n\n    }\n    fmt.Printf(\" ]\\n\")\n\n}\n",
